<header class="store-header sticky top-0 z-50"
  style="background-color: {{ theme.settings.get('header_bg_color', '#ffffff') }};
         color: {{ theme.settings.get('header_text_color', '#1f2937') }};">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between py-3">

      {# ── Logo ── #}
      <a href="{{ link('/') }}" class="flex-shrink-0">
        {% if theme.settings.get('site_logo') %}
          <img src="{{ theme.settings.get('site_logo') }}" alt="{{ store.name }}" class="h-10 w-auto">
        {% else %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" class="h-10 w-auto">
        {% endif %}
      </a>

      {# ── Desktop navigation ── #}
      <nav class="hidden lg:flex items-center gap-6" aria-label="{{ trans('common.elements.main_menu') }}">
        <salla-menu>
        {% for menu in menus %}
          <div class="relative group">
            <a href="{{ menu.url }}" class="text-sm font-medium transition-opacity hover:opacity-80"
               style="color: {{ theme.settings.get('header_text_color', '#1f2937') }};">
              {{ menu.title }}
            </a>
            {% if menu.children is not empty %}
              <div class="absolute top-full right-0 mt-2 bg-white shadow-lg rounded-lg py-2 min-w-[200px]
                          opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
                {% for child in menu.children %}
                  <a href="{{ child.url }}" class="block px-4 py-2 text-sm hover:bg-gray-50">
                    {{ child.title }}
                  </a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
        </salla-menu>
      </nav>

      {# ── Actions ── #}
      <div class="flex items-center gap-3"
           style="color: {{ theme.settings.get('header_accent_color', theme.settings.get('header_text_color', '#1f2937')) }};">
        <salla-search></salla-search>
        <salla-cart-icon></salla-cart-icon>
        {% if user.isLoggedIn %}
          <salla-user-icon></salla-user-icon>
        {% else %}
          <a href="{{ link('login') }}" class="text-sm font-medium transition-colors hover:underline"
             style="color: {{ theme.settings.get('header_accent_color', theme.settings.get('header_text_color', '#1f2937')) }};">
            {{ trans('common.elements.login') }}
          </a>
        {% endif %}

        {# ── Mobile menu toggle ── #}
        <button class="lg:hidden p-2" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')"
                aria-label="{{ trans('common.elements.menu') }}">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    {# ── Breadcrumbs (non-home pages) ── #}
    {% if breadcrumbs is defined and breadcrumbs is not empty %}
      <nav class="py-2 text-sm border-t" aria-label="Breadcrumb"
           style="border-color: {{ theme.settings.get('header_accent_color', theme.settings.get('header_text_color', '#1f2937')) }}1a;">
        <ol class="flex items-center gap-1 flex-wrap">
          {% for crumb in breadcrumbs %}
            <li>
              {% if not loop.last %}
                <a href="{{ crumb.url }}" class="hover:underline opacity-70"
                   style="color: {{ theme.settings.get('header_text_color', '#1f2937') }};">{{ crumb.title }}</a>
                <span class="mx-2 opacity-40">/</span>
              {% else %}
                <span class="opacity-100 font-medium"
                      style="color: {{ theme.settings.get('header_text_color', '#1f2937') }};">{{ crumb.title }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      </nav>
    {% endif %}
  </div>

  {# ── Mobile menu (hidden by default) ── #}
  <div id="mobile-menu" class="hidden lg:hidden border-t bg-white px-4 py-3">
    <nav class="flex flex-col gap-2">
      {% for menu in menus %}
        <a href="{{ menu.url }}" class="py-2 text-sm font-medium border-b last:border-0"
           style="color: {{ theme.settings.get('header_text_color', '#1f2937') }};">
          {{ menu.title }}
        </a>
      {% endfor %}
    </nav>
  </div>
</header>
