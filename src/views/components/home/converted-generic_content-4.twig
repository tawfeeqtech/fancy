<section dir="auto" class="section section--sm" {% if component.spacing_top %} data-spacing-top="true"{% endif %} {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
<div class="container">
<div style="background:{% raw %}{{ component.background_color ?: 'var(--color-primary-subtle)' }}{% endraw %};border-radius:var(--radius-lg);padding:var(--space-6) var(--space-4);text-align:center">
{% raw %}{% if component.badge_text %}{% endraw %}
<span style="display:inline-block;background:var(--color-accent);color:white;padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);font-size:0.75rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:var(--space-3)">
{% raw %}{{ component.badge_text }}{% endraw %}
</span>
{% raw %}{% endif %}{% endraw %}
{% raw %}{% if component.title %}{% endraw %}
<h2 style="font-family:var(--font-primary);font-size:{% raw %}{{ component.title_font_size ?: '1.8rem' }}{% endraw %};font-weight:600;margin-bottom:var(--space-2);color:{% raw %}{{ component.title_color ?: 'var(--converted-heading)' }}{% endraw %}">
{% raw %}{{ component.title }}{% endraw %}
</h2>
{% raw %}{% endif %}{% endraw %}
{% raw %}{% if component.description %}{% endraw %}
<p style="color:{% raw %}{{ component.description_color ?: 'var(--color-text-secondary)' }}{% endraw %};margin-bottom:var(--space-4);max-width:400px;margin-left:auto;margin-right:auto">
{% raw %}{{ component.description }}{% endraw %}
</p>
{% raw %}{% endif %}{% endraw %}
{% raw %}{% if component.show_button and component.button_text %}{% endraw %}
<a href="{% raw %}{{ component.button_link }}{% endraw %}" class="btn btn-primary" style="background-color:{% raw %}{{ component.button_bg_color ?: 'var(--converted-btn-bg)' }}{% endraw %};color:{% raw %}{{ component.button_color ?: 'var(--converted-btn-text)' }}{% endraw %}">
{% raw %}{{ component.button_text }}{% endraw %}
</a>
{% raw %}{% endif %}{% endraw %}
</div>
</div>
</section>