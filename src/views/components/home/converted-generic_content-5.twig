<section dir="auto" class="section" aria-labelledby="bestsellers-title"
  style="background-color: {{ component.background_color ?: 'var(--converted-bg)' }}"
  {% if component.spacing_top %} data-spacing-top="true"{% endif %}
  {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
  <div class="container">
    <div class="section-header">
      <h2 class="section-header__title" id="bestsellers-title">{{ component.title }}</h2>
      {% if component.view_all_text and component.view_all_link %}
      <a class="section-header__link" href="{{ component.view_all_link }}">{{ component.view_all_text }}</a>
      {% endif %}
    </div>
    <div class="grid-2">
      {% for item in component.products %}
      <div class="product-card animate-in {% if loop.index0 == 1 %}animate-in--delay-1{% endif %}">
        <div class="product-card__image-wrapper">
          {% if item.image %}
          <img src="{{ item.image }}" alt="{{ item.title }}" style="width:100%;height:100%;object-fit:cover;">
          {% else %}
          <div style="width:100%;height:100%;background:var(--color-primary-subtle);display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
            <i class="fas fa-tshirt"></i>
          </div>
          {% endif %}
          <button aria-label="إضافة إلى المفضلة" class="product-card__wishlist" onclick="this.classList.toggle('active')">
            <i class="far fa-heart"></i>
          </button>
          <button class="product-card__quick-add btn btn-primary btn-block" onclick="showToast('تمت الإضافة إلى السلة')" style="border-radius:var(--radius-full);padding:var(--space-2)">
            <i class="fas fa-plus"></i> {{ component.add_to_cart_text ?: 'أضف للسلة' }}
          </button>
        </div>
        <div class="product-card__info">
          <div class="product-card__title">{{ item.title }}</div>
          <div class="product-card__price">
            {% if item.price_current %}
            <span class="product-card__price-current">{{ item.price_current }}</span>
            {% endif %}
            {% if item.price_original %}
            <span class="product-card__price-original">{{ item.price_original }}</span>
            {% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>