<section dir="auto" class="hero"{% if component.height %} data-height="{{ component.height }}"{% endif %}{% if component.spacing_top %} data-spacing-top{% endif %}{% if component.spacing_bottom %} data-spacing-bottom{% endif %}{% if component.alignment %} data-alignment="{{ component.alignment }}"{% endif %}{% if component.background_color %} style="background-color: {{ component.background_color }};"{% endif %}>
{% if component.background_image %}
  <style scoped>
    .hero {
      background-image: url('{{ component.background_image }}');
    }
  </style>
{% endif %}
  <div class="container" style="position:relative;z-index:2">
    <div class="hero__content"{% if component.alignment %} style="text-align: {{ component.alignment }};"{% endif %}>
      {% if component.subtitle %}
        <span class="hero__badge">{{ component.subtitle }}</span>
      {% endif %}
      {% if component.title %}
        <h1 class="hero__title"><span>{{ component.title }}</span></h1>
      {% endif %}
      {% if component.subtitle %}
        <p class="hero__subtitle">{{ component.subtitle }}</p>
      {% endif %}
      {% if component.show_button and component.button_text %}
        <button class="btn btn-primary" onclick="showToast('جاري التوجيه للمجموعة...')" style="background-color: {{ component.button_bg_color }}; color: {{ component.button_color }};">
          {{ component.button_text }}
          <i class="fas fa-arrow-left"></i>
        </button>
      {% endif %}
    </div>
  </div>
  <div aria-hidden="true" class="hero__image">
    <i class="fas fa-tshirt" style="font-size:200px;color:var(--color-primary);opacity:0.3"></i>
  </div>
</section>