{# hero — Custom Salla Component #}
{% if component.background_image %}
<style scoped>
  .salla-component--home-converted-hero {
    background-image: url({{ component.background_image }});
    background-size: cover;
    background-position: center;
  }
</style>
{% endif %}
<section class="hero-gradient relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden salla-component salla-component--home-converted-hero" data-bg-image="{{ component.background_image }}" data-height="{{ component.height }}" data-spacing-bottom="true" data-spacing-top="true" dir="auto" id="home" style="background-color: {{ component.background_color }}; text-align: {{ component.alignment }}; color: {{ component.text_color }}; --overlay-opacity: {{ component.overlay_opacity  | default('40') }}%;">
<!-- Decorative Elements -->

  {% for item in component.items %}
  <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-100 rounded-full blur-3xl opacity-40 animate-float"></div>
  {% endfor %}


<div class="max-w-7xl mx-auto px-6 lg:px-8">
<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
<!-- Text Content -->
<div class="relative z-10">

  {% for item in component.items %}
  <div class="animate-fadeInUp opacity-0" style="animation-fill-mode: forwards;">
<div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-800 text-xs font-semibold px-4 py-2 rounded-full mb-6">
<span class="iconify" data-icon="lucide:trophy"></span>
                            المدرب الأول في المملكة العربية السعودية
                        </div>
</div>
  {% endfor %}
<h1 class="animate-fadeInUp opacity-0 delay-100 text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight mb-6" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color }};animation-fill-mode: forwards;">{% if component.title %}{{ component.title }}{% endif %}<span class="text-emerald-800">وحياتك</span>
                        مع كوتش محمد
                    </h1>
<p class="animate-fadeInUp opacity-0 delay-200 text-lg text-neutral-600 leading-relaxed mb-8 max-w-lg" style="animation-fill-mode: forwards;">{% if component.subtitle %}{{ component.subtitle }}{% endif %}</p>

<!-- Mini Stats -->

</div>
<!-- Hero Image -->
<div class="relative animate-fadeInRight opacity-0 delay-200" style="animation-fill-mode: forwards;">
<div class="relative z-10">
<img alt="كوتش محمد" class="w-full h-[450px] lg:h-[600px] object-cover rounded-3xl shadow-2xl" src="{{ component.background_image }}"/>
<div class="absolute inset-0 rounded-3xl bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
</div>
<!-- Floating Card 1 -->
<div class="absolute -bottom-6 -right-4 lg:-right-8 glass-card rounded-2xl p-4 shadow-xl animate-float z-20">
<div class="flex items-center gap-3">
<div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center">
<span class="iconify text-emerald-700 text-2xl" data-icon="lucide:flame"></span>
</div>
<div>
<div class="text-sm font-bold">نتائج مضمونة</div>
<div class="text-xs text-neutral-500">تحول حقيقي في 90 يوم</div>
</div>
</div>
</div>
<!-- Floating Card 2 -->
<div class="absolute top-8 -left-4 lg:-left-8 glass-card rounded-2xl p-4 shadow-xl animate-float z-20" style="animation-delay: 1.5s;">
<div class="flex items-center gap-3">
<div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center">
<span class="iconify text-amber-600 text-2xl" data-icon="lucide:crown"></span>
</div>
<div>
<div class="text-sm font-bold">باقات VIP</div>
<div class="text-xs text-neutral-500">تجربة نخبوية كاملة</div>
</div>
</div>
</div>
</div>
</div>
</div>
</section>
