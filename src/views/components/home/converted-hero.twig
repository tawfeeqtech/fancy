<section aria-label="العرض الرئيسي" class="hero" dir="auto" data-height="{{ component.height }}" data-spacing-top="{{ component.spacing_top ? 'true' : 'false' }}" data-spacing-bottom="{{ component.spacing_bottom ? 'true' : 'false' }}" style="background-color: {{ component.background_color }};">
<div class="container" style="position:relative;z-index:2">
<div class="hero__content" style="text-align: {{ component.alignment }};">
<span class="hero__badge">مجموعة الربيع</span>
{% if component.title %}
<h1 class="hero__title" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color }};"><span>{{ component.title }}</span></h1>
{% endif %}
{% if component.subtitle %}
<p class="hero__subtitle" style="font-size: {{ component.subtitle_font_size }}px; color: {{ component.subtitle_color }};">{{ component.subtitle }}</p>
{% endif %}
{% if component.show_button and component.button_text %}
<a href="{{ component.button_link }}" class="btn {% if component.button_style %}btn-{{ component.button_style }}{% else %}btn-primary{% endif %}" style="{% if component.button_bg_color %}background-color: {{ component.button_bg_color }};{% endif %} {% if component.button_color %}color: {{ component.button_color }};{% endif %} {% if component.button_size %}font-size: {{ component.button_size }}px;{% endif %}">
                        {{ component.button_text }}
                        <i class="fas fa-arrow-left"></i>
</a>
{% endif %}
</div>
</div>
<div aria-hidden="true" class="hero__image">
<i class="fas fa-tshirt" style="font-size:200px;color:var(--color-primary);opacity:0.3"></i>
</div>
</section>