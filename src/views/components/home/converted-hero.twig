<section dir="auto" class="hero" aria-label="العرض الرئيسي"
    style="background-color: {{ component.background_color ?: 'var(--converted-primary)' }};"
    {% if component.spacing_top %} data-spacing-top="true"{% endif %}
    {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
    {% if component.background_image %}
    <style scoped>
        .hero {
            background-image: url({{ component.background_image }});
            background-size: cover;
            background-position: center;
        }
    </style>
    {% endif %}
    <div class="container" style="position:relative;z-index:2">
        <div class="hero__content">
            {% if component.badge_text %}
            <span class="hero__badge">{{ component.badge_text }}</span>
            {% endif %}
            {% if component.title %}
            <h1 class="hero__title {{ component.title_font_size }}" style="color: {{ component.title_color ?: 'var(--converted-heading)' }};">
                {{ component.title }}
            </h1>
            {% endif %}
            {% if component.subtitle %}
            <p class="hero__subtitle {{ component.subtitle_font_size }}" style="color: {{ component.subtitle_color ?: 'var(--converted-text)' }};">
                {{ component.subtitle }}
            </p>
            {% endif %}
            {% if component.show_button and component.button_text %}
            <a href="{{ component.button_link }}" class="btn btn-primary {{ component.button_size }}" onclick="showToast('جاري التوجيه للمجموعة...')" style="background-color: {{ component.button_bg_color ?: 'var(--converted-btn-bg)' }}; color: {{ component.button_color ?: 'var(--converted-btn-text)' }};">
                {{ component.button_text }}
                <i class="fas fa-arrow-left"></i>
            </a>
            {% endif %}
        </div>
    </div>
    <div aria-hidden="true" class="hero__image">
        <i class="fas fa-tshirt" style="font-size:200px;color:var(--color-primary);opacity:0.3"></i>
    </div>
</section>