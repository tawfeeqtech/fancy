{# lead-form — Custom Salla Component #}
{% if component.background_image %}
<style scoped>
  .salla-component--home-converted-lead_form {
    background-image: url({{ component.background_image }});
    background-size: cover;
    background-position: center;
  }
</style>
{% endif %}
<section class="section-gradient py-20 lg:py-32 salla-component salla-component--home-converted-lead_form" data-bg-image="{{ component.background_image }}" data-spacing-bottom="true" data-spacing-top="true" dir="auto" id="contact" style="background-color: {{ component.background_color }}; text-align: {{ component.alignment }};">
<div class="max-w-7xl mx-auto px-6 lg:px-8">
<div class="grid lg:grid-cols-2 gap-16">
<!-- Contact Info -->
<div class="scroll-reveal">
<div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-800 text-xs font-semibold px-4 py-2 rounded-full mb-6">
<span class="iconify" data-icon="lucide:mail"></span>
                        تواصل معنا
                    </div>
<h2 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight mb-6" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color }}">{% if component.title %}{{ component.title }}{% endif %}<span class="text-emerald-800">رحلتك؟</span>
</h2>
<p class="text-lg text-neutral-600 leading-relaxed mb-10">{% if component.subtitle %}{{ component.subtitle }}{% endif %}</p>
<div class="space-y-6">

  {% for item in component.items %}
  <div class="flex items-center gap-4">
<div class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center flex-shrink-0">
<span class="iconify text-emerald-700 text-xl" data-icon="lucide:phone"></span>
</div>
<div>
<div class="text-sm text-neutral-500">اتصل بنا</div>
<div class="font-semibold font-inter" dir="ltr">+966 50 123 4567</div>
</div>
</div>
  {% endfor %}



</div>
<!-- Social Media -->
<div class="mt-10 flex items-center gap-3">

  {% for item in component.items %}
  <a class="w-11 h-11 rounded-xl bg-neutral-100 flex items-center justify-center text-neutral-500 hover:bg-emerald-800 hover:text-white transition-all duration-300" href="{{ component.link }}" style="color: {{ component.button_color }}; background-color: {{ component.button_bg_color }}">
<span class="iconify text-lg" data-icon="lucide:instagram"></span>
</a>
  {% endfor %}



</div>
</div>
<!-- Contact Form -->
<div class="scroll-reveal">
<form class="bg-white rounded-2xl p-8 shadow-xl border border-neutral-100" id="contactForm" onsubmit="handleFormSubmit(event)">
<h3 class="text-xl font-bold mb-6">{% if component.subtitle %}{{ component.subtitle }}{% endif %}</h3>
<div class="grid sm:grid-cols-2 gap-4 mb-4">
<div>
<label class="block text-sm font-medium text-neutral-700 mb-2">الاسم الأول</label>
<input class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all duration-300 text-sm" placeholder="محمد" required="" type="text"/>
</div>
<div>
<label class="block text-sm font-medium text-neutral-700 mb-2">الاسم الأخير</label>
<input class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all duration-300 text-sm" placeholder="العتيبي" required="" type="text"/>
</div>
</div>

  {% for item in component.items %}
  <div class="mb-4">
<label class="block text-sm font-medium text-neutral-700 mb-2">البريد الإلكتروني</label>
<input class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all duration-300 text-sm text-left" dir="ltr" placeholder="example@email.com" required="" type="email"/>
</div>
  {% endfor %}


<div class="mb-6">
<label class="block text-sm font-medium text-neutral-700 mb-2">رسالتك</label>
<textarea class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 outline-none transition-all duration-300 text-sm resize-none" placeholder="أخبرنا عن أهدافك في اللياقة البدنية..." required="" rows="4"></textarea>
</div>
<button class="w-full bg-emerald-800 text-white font-semibold py-3.5 rounded-full hover:bg-emerald-700 hover:-translate-y-0.5 transition-all duration-300 shadow-lg shadow-emerald-800/20 flex items-center justify-center gap-2" type="submit">
                            إرسال الرسالة
                            <span class="iconify" data-icon="lucide:send"></span>
</button>
</form>
</div>
</div>
</div>
</section>
