{# generic-content — Custom Salla Component #}
<section dir="auto" class="salla-component salla-component--home-converted-generic_content-2">
<section class="section section--sm">
<div class="container">
<div style="background:var(--color-primary-subtle);border-radius:var(--radius-lg);padding:var(--space-6) var(--space-4);text-align:center">
<span style="display:inline-block;background:var(--color-accent);color:white;padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);font-size:0.75rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:var(--space-3)">
                        مجموعة الصيف
                    </span>
<h2 style="font-family:var(--font-primary);font-size:1.8rem;font-weight:600;margin-bottom:var(--space-2)">{{ component.title }}</h2>
<p style="color:var(--color-text-secondary);margin-bottom:var(--space-4);max-width:400px;margin-left:auto;margin-right:auto">{{ component.description }}</p>
<button class="btn btn-primary" onclick="showToast('جاري التوجيه للمجموعة...')">
                        اكتشفي المجموعة
                    </button>
</div>
</div>
</section>
</section>
