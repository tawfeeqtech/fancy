{# generic-content — Custom Salla Component #}
{% if component.background_image %}
<style scoped>
  .salla-component--home-converted-generic_content-2 {
    background-image: url({{ component.background_image }});
    background-size: cover;
    background-position: center;
  }
</style>
{% endif %}
<section class="section-gradient py-20 lg:py-32 salla-component salla-component--home-converted-generic_content-2" data-bg-image="{{ component.background_image }}" data-spacing-bottom="true" data-spacing-top="true" dir="auto" style="background-color: {{ component.background_color }}; text-align: {{ component.alignment }};">
<div class="max-w-7xl mx-auto px-6 lg:px-8">
<div class="text-center max-w-2xl mx-auto mb-16 scroll-reveal">
<div class="inline-flex items-center gap-2 bg-emerald-100 text-emerald-800 text-xs font-semibold px-4 py-2 rounded-full mb-6">
<span class="iconify" data-icon="lucide:sparkles"></span>
                    لماذا تختارنا
                </div>
<h2 class="text-3xl sm:text-4xl font-bold leading-tight tracking-tight mb-4" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color }}">{% if component.title %}{{ component.title }}{% endif %}<span class="text-emerald-800">استثنائية</span>
</h2>
<p class="text-lg text-neutral-500" style="font-size: {{ component.description_font_size }}px; color: {{ component.description_color }}">{% if component.description %}{{ component.description }}{% endif %}</p>
</div>
<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
<!-- Feature 1 -->

  {% for item in component.items %}
  <div class="scroll-reveal bg-white rounded-2xl p-7 border border-neutral-100 hover:border-emerald-200 hover:shadow-xl transition-all duration-300 group">
<div class="w-14 h-14 rounded-2xl bg-emerald-100 flex items-center justify-center mb-5 group-hover:bg-emerald-800 transition-colors duration-300">
<span class="iconify text-emerald-700 text-2xl group-hover:text-white transition-colors duration-300" data-icon="lucide:target"></span>
</div>
<h3 class="text-xl font-bold mb-3">{{ item.title }}</h3>
<p class="text-neutral-500 leading-relaxed">{{ item.description }}</p>
</div>
  {% endfor %}
<!-- Feature 2 -->

<!-- Feature 3 -->

<!-- Feature 4 -->

<!-- Feature 5 -->

<!-- Feature 6 -->

</div>
</div>
</section>
