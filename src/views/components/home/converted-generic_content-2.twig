<section dir="auto" aria-labelledby="categories-title" class="section section--sm" {% if component.spacing_top %} data-spacing-top="true"{% endif %}{% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
<div class="container">
<div class="section-header">
<h2 class="section-header__title" id="categories-title">{{ component.title }}</h2>
</div>
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-2);text-align:center">
{% for item in component.categories %}
<div onclick="window.location.href='{{ item.category_link }}'" style="cursor:pointer">
<div onmouseover="this.style.background='var(--color-border)'" style="width:64px;height:64px;border-radius:var(--radius-full);background:var(--color-primary-subtle);margin:0 auto var(--space-1);display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--color-secondary);transition:var(--transition-smooth)">
<i class="{{ item.icon }}"></i>
</div>
<span style="font-size:0.75rem;font-weight:500">{{ item.label }}</span>
</div>
{% endfor %}
</div>
</div>
</section>