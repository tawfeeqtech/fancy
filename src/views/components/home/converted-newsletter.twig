<section dir="auto" aria-labelledby="newsletter-title" class="section{% if component.background_image %} newsletter-section-bg{% endif %}" {% if component.spacing_top %} data-spacing-top="true"{% endif %}{% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %} style="background-color: {{ component.background_color ?: 'var(--converted-bg)' }};{% if component.alignment %} text-align: {{ component.alignment }};{% endif %}">{% if component.background_image %}<style scoped>.newsletter-section-bg { background-image: url({{ component.background_image }}); background-size: cover; background-position: center; }</style>{% endif %}<div class="container"><div class="newsletter">{% if component.title %}<h2 class="newsletter__title" id="newsletter-title" style="{% if component.title_color %}color: {{ component.title_color }};{% else %}color: var(--converted-heading);{% endif %}{% if component.title_font_size %}font-size: {{ component.title_font_size }}px;{% endif %}">{{ component.title }}</h2>{% endif %}{% if component.subtitle %}<p class="newsletter__subtitle" style="{% if component.subtitle_color %}color: {{ component.subtitle_color }};{% else %}color: var(--converted-text);{% endif %}{% if component.subtitle_font_size %}font-size: {{ component.subtitle_font_size }}px;{% endif %}">{{ component.subtitle }}</p>{% endif %}<form class="newsletter__form" onsubmit="event.preventDefault();showToast('شكراً لانضمامك!')"><input aria-label="البريد الإلكتروني" placeholder="{{ component.placeholder_text }}" required="" type="email"/><button class="btn btn-primary" type="submit" style="color: {{ component.button_color ?: 'var(--converted-btn-text)' }}; background-color: {{ component.button_bg_color ?: 'var(--converted-btn-bg)' }};">{{ component.button_text }}</button></form></div></div></section>