<section id="newsletter-section" dir="auto" aria-labelledby="newsletter-title" class="section" style="background-color: {{ component.background_color ?: 'var(--color-bg)' }}" {% if component.spacing_top %} data-spacing-top="true"{% endif %} {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
  {% if component.background_image %}
  <style scoped>
    #newsletter-section {
      background-image: url({{ component.background_image }});
      background-size: cover;
      background-position: center;
    }
  </style>
  {% endif %}
  <div class="container">
    <div class="newsletter" style="color: {{ component.text_color ?: 'var(--color-text)' }}; {% if component.alignment %}text-align: {{ component.alignment }};{% endif %}">
      {% if component.title %}
      <h2 class="newsletter__title" id="newsletter-title" style="color: {{ component.title_color ?: 'var(--color-heading)' }}; font-size: {{ component.title_font_size }}px;">{{ component.title }}</h2>
      {% endif %}
      {% if component.subtitle %}
      <p class="newsletter__subtitle" style="color: {{ component.subtitle_color ?: 'var(--color-text)' }}; font-size: {{ component.subtitle_font_size }}px;">{{ component.subtitle }}</p>
      {% endif %}
      {% if component.button_text %}
      <form class="newsletter__form" onsubmit="event.preventDefault();showToast('{{ component.success_message }}')">
        {% if component.placeholder_text %}
        <input aria-label="{{ component.placeholder_text }}" placeholder="{{ component.placeholder_text }}" required="" type="email"/>
        {% endif %}
        <button class="btn btn-primary" type="submit" style="color: {{ component.button_color ?: 'var(--color-bg)' }}; background-color: {{ component.button_bg_color ?: 'var(--color-primary)' }}; font-size: {{ component.button_size }}px;">{{ component.button_text }}</button>
      </form>
      {% endif %}
    </div>
  </div>
</section>