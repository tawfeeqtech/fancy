{% if component.background_image %}
<style scoped>
  .newsletter-section-bg {
    background-image: url({{ component.background_image }});
    background-size: cover;
    background-position: center;
  }
</style>
{% endif %}
<section dir="auto" aria-labelledby="newsletter-title" class="section{% if component.background_image %} newsletter-section-bg{% endif %}"
         style="background-color: {{ component.background_color ?: 'var(--color-bg)' }};"
         {% if component.spacing_top %} data-spacing-top="true"{% endif %}
         {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
  <div class="container">
    <div class="newsletter" style="{% if component.alignment %}text-align: {{ component.alignment }};{% endif %}{% if component.text_color %}color: {{ component.text_color }};{% endif %}">
      {% if component.title %}
      <h2 class="newsletter__title" id="newsletter-title" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color ?: 'var(--color-heading)' }};">{{ component.title }}</h2>
      {% endif %}
      {% if component.subtitle %}
      <p class="newsletter__subtitle" style="font-size: {{ component.subtitle_font_size }}px; color: {{ component.subtitle_color ?: 'var(--color-text)' }};">{{ component.subtitle }}</p>
      {% endif %}
      <form class="newsletter__form" onsubmit="event.preventDefault();showToast('{{ component.success_message }}')">
        <input aria-label="{{ component.placeholder_text }}" placeholder="{{ component.placeholder_text }}" required="" type="email"/>
        {% if component.button_text %}
        <button class="btn btn-primary" type="submit" style="font-size: {{ component.button_size }}px; color: {{ component.button_color ?: 'var(--color-bg)' }}; background-color: {{ component.button_bg_color ?: 'var(--color-primary)' }};">{{ component.button_text }}</button>
        {% endif %}
      </form>
    </div>
  </div>
</section>