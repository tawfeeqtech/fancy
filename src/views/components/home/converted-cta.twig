<section dir="auto" aria-labelledby="newsletter-title" class="section" style="background-color: {% raw %}{{ component.background_color ?: 'var(--converted-bg)' }}{% endraw %};" {% raw %}{% if component.spacing_top %}data-spacing-top="true"{% endif %}{% endraw %} {% raw %}{% if component.spacing_bottom %}data-spacing-bottom="true"{% endif %}{% endraw %}>
<div class="container">
<div class="newsletter" style="text-align: {% raw %}{{ component.alignment ?: 'center' }}{% endraw %};">
{% raw %}{% if component.title %}{% endraw %}
<h2 class="newsletter__title" id="newsletter-title" style="color: {% raw %}{{ component.title_color ?: 'var(--converted-heading)' }}{% endraw %}; font-size: {% raw %}{{ component.title_font_size ?: 'inherit' }}{% endraw %};">{% raw %}{{ component.title }}{% endraw %}</h2>
{% raw %}{% endif %}{% endraw %}
{% raw %}{% if component.subtitle %}{% endraw %}
<p class="newsletter__subtitle" style="color: {% raw %}{{ component.subtitle_color ?: 'var(--converted-text)' }}{% endraw %}; font-size: {% raw %}{{ component.subtitle_font_size ?: 'inherit' }}{% endraw %};">{% raw %}{{ component.subtitle }}{% endraw %}</p>
{% raw %}{% endif %}{% endraw %}
<form class="newsletter__form" onsubmit="event.preventDefault();showToast('شكراً لانضمامك!')">
<input aria-label="البريد الإلكتروني" placeholder="بريدك الإلكتروني" required="" type="email"/>
{% raw %}{% if component.button_text %}{% endraw %}
<button class="btn btn-primary" type="submit" style="background-color: {% raw %}{{ component.button_bg_color ?: 'var(--converted-btn-bg)' }}{% endraw %}; color: {% raw %}{{ component.button_color ?: 'var(--converted-btn-text)' }}{% endraw %};">{% raw %}{{ component.button_text }}{% endraw %}</button>
{% raw %}{% endif %}{% endraw %}
</form>
</div>
</div>
</section>