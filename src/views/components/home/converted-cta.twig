<section aria-labelledby="newsletter-title" class="section" dir="auto" {% if component.spacing_top %} data-spacing-top="true"{% endif %} {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %} style="background-color: {{ component.background_color ?: 'var(--converted-bg)' }};">
  <div class="container">
    <div class="newsletter">
      {% if component.title %}
      <h2 class="newsletter__title" id="newsletter-title" style="color: {{ component.title_color ?: 'var(--converted-heading)' }}; font-size: {{ component.title_font_size }}px;">{{ component.title }}</h2>
      {% endif %}
      {% if component.subtitle %}
      <p class="newsletter__subtitle" style="color: {{ component.subtitle_color ?: 'var(--converted-text)' }};">{{ component.subtitle }}</p>
      {% endif %}
      <form class="newsletter__form" onsubmit="event.preventDefault();showToast('شكراً لانضمامك!')">
        <input aria-label="البريد الإلكتروني" placeholder="بريدك الإلكتروني" required="" type="email"/>
        {% if component.button_text %}
        <button class="btn btn-primary" type="submit" style="background-color: {{ component.button_bg_color ?: 'var(--converted-btn-bg)' }}; color: {{ component.button_color ?: 'var(--converted-btn-text)' }};">{{ component.button_text }}</button>
        {% endif %}
      </form>
    </div>
  </div>
</section>