{# cta — Custom Salla Component #}
<section dir="auto" class="salla-component salla-component--home-converted-cta">
<section aria-labelledby="newsletter-title" class="section">
<div class="container">
<div class="newsletter">
<h2 class="newsletter__title" id="newsletter-title">{{ component.title }}</h2>
<p class="newsletter__subtitle">{{ component.description }}</p>
<form class="newsletter__form" onsubmit="event.preventDefault();showToast('شكراً لانضمامك!')">
<input aria-label="البريد الإلكتروني" placeholder="بريدك الإلكتروني" required="" type="email"/>
<button class="btn btn-primary" type="submit">اشتراك</button>
</form>
</div>
</div>
</section>
</section>
