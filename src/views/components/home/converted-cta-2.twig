<section dir="auto" class="section section--sm" {% if component.spacing_top %} data-spacing-top="true"{% endif %} {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
<div class="container">
<div style="background:var(--color-primary-subtle);border-radius:var(--radius-lg);padding:var(--space-6) var(--space-4);text-align:center">
{% if component.badge_text %}
<span style="display:inline-block;background:var(--color-accent);color:white;padding:var(--space-1) var(--space-4);border-radius:var(--radius-full);font-size:0.75rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:var(--space-3)">
{{ component.badge_text }}
</span>
{% endif %}
{% if component.title %}
<h2 style="font-family:var(--font-primary);font-size:{{ component.title_font_size }};font-weight:600;margin-bottom:var(--space-2); color:{{ component.title_color ?: 'var(--converted-heading)' }}">
{{ component.title }}
</h2>
{% endif %}
{% if component.subtitle %}
<p style="color:{{ component.subtitle_color ?: 'var(--converted-text)' }};margin-bottom:var(--space-4);max-width:400px;margin-left:auto;margin-right:auto">
{{ component.subtitle }}
</p>
{% endif %}
{% if component.button_text %}
<a href="{{ component.button_link }}" class="btn btn-primary {{ component.button_size }}" style="background-color: {{ component.button_bg_color ?: 'var(--converted-btn-bg)' }}; color: {{ component.button_color ?: 'var(--converted-btn-text)' }};">
{{ component.button_text }}
</a>
{% endif %}
</div>
</div>
</section>