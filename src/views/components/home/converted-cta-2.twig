{# cta — Custom Salla Component #}
{% if component.background_image %}
<style scoped>
  .salla-component--home-converted-cta-2 {
    background-image: url({{ component.background_image }});
    background-size: cover;
    background-position: center;
  }
</style>
{% endif %}
<section class="relative py-20 lg:py-28 overflow-hidden salla-component salla-component--home-converted-cta-2" data-bg-image="{{ component.background_image }}" data-spacing-bottom="true" data-spacing-top="true" dir="auto" style="background-color: {{ component.background_color }}; text-align: {{ component.alignment }}; color: {{ component.text_color }};">
<div class="absolute inset-0">
<img alt="خلفية رياضية" class="w-full h-full object-cover" src="{{ component.background_image }}"/>
<div class="absolute inset-0 bg-gradient-to-l from-emerald-900/90 via-emerald-800/85 to-neutral-950/90"></div>
</div>
<div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
<div class="scroll-reveal">
<div class="inline-flex items-center gap-2 bg-white/10 text-emerald-300 text-xs font-semibold px-4 py-2 rounded-full mb-6 backdrop-blur-sm">
<span class="iconify" data-icon="lucide:zap"></span>
                    ابدأ رحلتك اليوم
                </div>
<h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-tight mb-6" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color }}">{% if component.title %}{{ component.title }}{% endif %}<br/>يبعد باقة واحدة فقط
                </h2>
<p class="text-lg text-emerald-100/80 leading-relaxed mb-10 max-w-2xl mx-auto">{% if component.subtitle %}{{ component.subtitle }}{% endif %}</p>
<div class="flex flex-wrap justify-center gap-4">
<a class="inline-flex items-center gap-2 bg-white text-emerald-900 text-base font-bold px-8 py-4 rounded-full hover:bg-emerald-50 hover:-translate-y-0.5 transition-all duration-300 shadow-xl" href="{{ component.button_link }}" style="color: {{ component.button_color }}; background-color: {{ component.button_bg_color }}">{{ component.button_text }}<span class="iconify text-lg" data-icon="lucide:arrow-left"></span>
</a>
<a class="inline-flex items-center gap-2 bg-transparent text-white text-base font-medium px-8 py-4 rounded-full border-2 border-white/30 hover:border-white/60 hover:bg-white/10 transition-all duration-300" href="{{ component.button_secondary_link }}">{{ component.button_secondary_text }}</a>
</div>
</div>
</div>
</section>
