<section dir="auto" class="section section--sm" aria-labelledby="collections-title"
         style="background-color: {{ component.background_color ?: 'var(--converted-bg)' }}"
         {% if component.spacing_top %} data-spacing-top="true"{% endif %}
         {% if component.spacing_bottom %} data-spacing-bottom="true"{% endif %}>
  <div class="container">
    <div class="section-header">
      {% if component.title %}
      <h2 class="section-header__title" id="collections-title"
          style="font-size: {{ component.title_font_size ? component.title_font_size ~ 'px' : 'inherit' }}; color: {{ component.title_color ?: 'var(--converted-heading)' }};">
        {{ component.title }}
      </h2>
      {% endif %}
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3)">
      {% for item in component.collections %}
      <div class="category-card animate-in{% if loop.index == 1 %} animate-in--delay-1{% elseif loop.index == 2 %} animate-in--delay-2{% endif %}">
        <div style="background:var(--color-primary-subtle);height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
          <i class="{{ item.icon }}"></i>
        </div>
        <div class="category-card__overlay">
          <span class="category-card__title">{{ item.label }}</span>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>