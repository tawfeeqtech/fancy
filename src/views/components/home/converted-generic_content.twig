{# generic-content — Custom Salla Component #}
<section dir="auto" class="salla-component salla-component--home-converted-generic_content" style="background-color: {{ component.background_color }}; {% if component.background_image %}background-image: url({{ component.background_image }}); background-size: cover; background-position: center;{% endif %} text-align: {{ component.alignment }}; {% if component.spacing_top %}padding-top: 80px;{% endif %} {% if component.spacing_bottom %}padding-bottom: 80px;{% endif %}">
<section aria-labelledby="collections-title" class="section section--sm">
<div class="container">
<div class="section-header">
<h2 class="section-header__title" id="collections-title" style="font-size: {{ component.title_font_size }}px; color: {{ component.title_color }}">{% if component.title %}{{ component.title }}{% endif %}</h2>
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3)">
<div class="category-card animate-in animate-in--delay-1">
<div style="background:var(--color-primary-subtle);height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
<i class="fas fa-moon"></i>
</div>
<div class="category-card__overlay">
<span class="category-card__title">المسائية</span>
</div>
</div>
<div class="category-card animate-in animate-in--delay-2">
<div style="background:var(--color-primary-subtle);height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
<i class="fas fa-sun"></i>
</div>
<div class="category-card__overlay">
<span class="category-card__title">النهارية</span>
</div>
</div>
</div>
</div>
</section>
</section>
