<section dir="auto" aria-labelledby="collections-title" class="section section--sm" data-spacing-top="{{ component.spacing_top }}" data-spacing-bottom="{{ component.spacing_bottom }}">
<div class="container">
<div class="section-header">
{% if component.title %}
{% set title_style = '' %}
{% if component.title_font_size %}
{% set title_style = title_style ~ 'font-size: ' ~ component.title_font_size ~ 'px;' %}
{% endif %}
{% if component.title_color %}
{% set title_style = title_style ~ 'color: ' ~ component.title_color ~ ';' %}
{% endif %}
<h2 class="section-header__title" id="collections-title"{% if title_style %} style="{{ title_style }}"{% endif %}>{{ component.title }}</h2>
{% endif %}
</div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3)">
<div class="category-card animate-in animate-in--delay-1">
<div style="background:var(--color-primary-subtle);height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
<i class="fas fa-moon"></i>
</div>
<div class="category-card__overlay">
<span class="category-card__title">المسائية</span>
</div>
</div>
<div class="category-card animate-in animate-in--delay-2">
<div style="background:var(--color-primary-subtle);height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
<i class="fas fa-sun"></i>
</div>
<div class="category-card__overlay">
<span class="category-card__title">النهارية</span>
</div>
</div>
</div>
</div>
</section>