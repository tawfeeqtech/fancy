<section dir="auto" class="section section--sm" aria-labelledby="collections-title">
  <div class="container">
    {% if component.title %}
    <div class="section-header">
      <h2 class="section-header__title" id="collections-title" style="color: {{ component.title_color ?: 'var(--converted-heading)' }}">{{ component.title }}</h2>
    </div>
    {% endif %}
    {% if component.categories %}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3)">
      {% for item in component.categories %}
      <div class="category-card animate-in animate-in--delay-{{ loop.index }}">
        <div style="background: {{ item.background_color ?: 'var(--color-primary-subtle)' }};height:100%;display:flex;align-items:center;justify-content:center;font-size:3rem;color: {{ item.icon_color ?: 'var(--color-secondary)' }}">
          <i class="{{ item.icon_class }}"></i>
        </div>
        <div class="category-card__overlay">
          <span class="category-card__title">{{ item.title }}</span>
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>