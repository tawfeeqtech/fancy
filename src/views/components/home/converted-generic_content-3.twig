<section dir="auto" class="section" {% if component.spacing_top %} data-spacing-top {% endif %} {% if component.spacing_bottom %} data-spacing-bottom {% endif %}>
<style scoped>
{% if component.background_color %}
section { background-color: {{ component.background_color }}; }
{% endif %}
{% if component.background_image %}
section {
  background-image: url('{{ component.background_image }}');
  background-size: cover;
  background-position: center;
}
{% endif %}
{% if component.alignment %}
.section-header {
  text-align: {{ component.alignment }};
}
{% endif %}
</style>
<div class="container">
  <div class="section-header">
    <h2 class="section-header__title" id="bestsellers-title" {% if component.title_font_size or component.title_color %} style="{% if component.title_font_size %}font-size: {{ component.title_font_size }}px; {% endif %}{% if component.title_color %}color: {{ component.title_color }};{% endif %}" {% endif %}>{{ component.title }}</h2>
    {% if component.show_button and component.button_text %}
    <a class="section-header__link" href="{{ component.button_link }}" {% if component.button_bg_color or component.button_color %} style="{% if component.button_bg_color %}background-color: {{ component.button_bg_color }}; {% endif %}{% if component.button_color %}color: {{ component.button_color }};{% endif %}" {% endif %}>{{ component.button_text }}</a>
    {% endif %}
  </div>
  <div class="grid-2">
    <div class="product-card animate-in">
      <div class="product-card__image-wrapper">
        <div style="width:100%;height:100%;background:var(--color-primary-subtle);display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
          <i class="fas fa-tshirt"></i>
        </div>
        <button aria-label="إضافة إلى المفضلة" class="product-card__wishlist" onclick="this.classList.toggle('active')">
          <i class="far fa-heart"></i>
        </button>
        <button class="product-card__quick-add btn btn-primary btn-block" onclick="showToast('تمت الإضافة إلى السلة')" style="border-radius:var(--radius-full);padding:var(--space-2)">
          <i class="fas fa-plus"></i> أضف للسلة
        </button>
      </div>
      <div class="product-card__info">
        <div class="product-card__title">عباية بيضاء أنيقة</div>
        <div class="product-card__price">
          <span class="product-card__price-current">1,050 ر.س</span>
        </div>
      </div>
    </div>
    <div class="product-card animate-in animate-in--delay-1">
      <div class="product-card__image-wrapper">
        <div style="width:100%;height:100%;background:var(--color-primary-subtle);display:flex;align-items:center;justify-content:center;font-size:3rem;color:var(--color-secondary)">
          <i class="fas fa-tshirt"></i>
        </div>
        <button aria-label="إضافة إلى المفضلة" class="product-card__wishlist" onclick="this.classList.toggle('active')">
          <i class="far fa-heart"></i>
        </button>
        <button class="product-card__quick-add btn btn-primary btn-block" onclick="showToast('تمت الإضافة إلى السلة')" style="border-radius:var(--radius-full);padding:var(--space-2)">
          <i class="fas fa-plus"></i> أضف للسلة
        </button>
      </div>
      <div class="product-card__info">
        <div class="product-card__title">عباية زرقاء داكنة فاخرة</div>
        <div class="product-card__price">
          <span class="product-card__price-current">1,300 ر.س</span>
          <span class="product-card__price-original">1,600 ر.س</span>
        </div>
      </div>
    </div>
  </div>
</div>
</section>