<footer class="store-footer"
  style="background-color: {{ theme.settings.get('footer_bg_color', '#0a0a0a') }};
         color: {{ theme.settings.get('footer_text_color', '#ffffff') }};">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">

      {# ── Store info + social ── #}
      <div class="md:col-span-1">
        <a href="{{ link('/') }}" class="block mb-4">
          {% if theme.settings.get('footer_logo') %}
            <img src="{{ theme.settings.get('footer_logo') }}"
                 alt="{{ store.name }}"
                 loading="lazy"
                 style="max-width: {{ theme.settings.get('footer_logo_width', '150') }}px;">
          {% else %}
            <h3 class="text-xl font-bold">{{ store.name }}</h3>
          {% endif %}
        </a>
        {% if store.description %}
          <p class="text-sm opacity-80 leading-relaxed mb-4">{{ store.description|raw }}</p>
        {% endif %}

        {% if theme.settings.get('footer_show_social', true) and footer.social_links is not empty %}
          <div class="flex gap-3">
            {% for link in footer.social_links %}
              <a href="{{ link.url }}" title="{{ link.name }}"
                 class="transition-all hover:-translate-y-0.5"
                 style="color: {{ theme.settings.get('footer_link_color', theme.settings.get('footer_text_color', '#ffffff')) }};">
                <i class="{{ link.icon }} text-xl"></i>
              </a>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {# ── Quick links ── #}
      {% if theme.settings.get('footer_show_pages', true) and footer.pages is not empty %}
        <div>
          <h4 class="font-bold mb-3">{{ trans('blocks.footer.quick_links') }}</h4>
          <ul class="space-y-2">
            {% for page in footer.pages %}
              <li>
                <a href="{{ page.link }}" class="text-sm transition-colors opacity-80"
                   style="color: {{ theme.settings.get('footer_link_color', theme.settings.get('footer_text_color', '#ffffff')) }};"
                   onmouseover="this.style.color='{{ theme.settings.get('footer_link_hover_color', theme.settings.get('footer_link_color', theme.settings.get('footer_text_color', '#ffffff'))) }}'"
                   onmouseout="this.style.color='{{ theme.settings.get('footer_link_color', theme.settings.get('footer_text_color', '#ffffff')) }}'">
                  {{ page.name }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {# ── Contacts ── #}
      {% if theme.settings.get('footer_show_contacts', true) and footer.contacts is not empty %}
        <div>
          <h4 class="font-bold mb-3">{{ trans('blocks.footer.contact_us') }}</h4>
          <ul class="space-y-2">
            {% for contact in footer.contacts %}
              <li>
                <a href="{{ contact.url }}" class="text-sm transition-colors opacity-80 flex items-center gap-2"
                   style="color: {{ theme.settings.get('footer_link_color', theme.settings.get('footer_text_color', '#ffffff')) }};">
                  <i class="{{ contact.icon }}"></i>
                  <span>{{ contact.value }}</span>
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {# ── Payment methods ── #}
      {% if theme.settings.get('footer_show_payments', true) and footer.payment_methods is not empty %}
        <div>
          <h4 class="font-bold mb-3">{{ trans('blocks.footer.payment_methods') }}</h4>
          <div class="flex flex-wrap gap-2">
            {% for method in footer.payment_methods %}
              <img src="{{ method.image }}" alt="{{ method.name }}"
                   class="h-8 rounded" loading="lazy" title="{{ method.name }}">
            {% endfor %}
          </div>
        </div>
      {% endif %}

    </div>

    {# ── Copyright bar ── #}
    <div class="border-t mt-8 pt-6 flex flex-col md:flex-row items-center justify-between text-sm opacity-70"
         style="border-color: {{ theme.settings.get('footer_text_color', '#ffffff') }}1a;">
      <span>{% hook copyright %}</span>
      {% if theme.settings.get('show_powered_by', true) %}
        <span class="mt-2 md:mt-0">
          {{ trans('blocks.footer.powered_by') }}
          <a href="https://salla.sa" target="_blank" rel="noopener" class="underline"
             style="color: {{ theme.settings.get('footer_link_color', theme.settings.get('footer_text_color', '#ffffff')) }};">Salla</a>
        </span>
      {% endif %}
    </div>

    {# ── Map (optional) ── #}
    {% if theme.settings.get('footer_show_map', false) and theme.settings.get('footer_map_embed') %}
      <div class="mt-8 rounded-lg overflow-hidden">
        {{ theme.settings.get('footer_map_embed')|raw }}
      </div>
    {% endif %}

    {# ── Bottom Alert (address + map selection, v2.14.451) ── #}
    <div class="mt-8">
      <salla-bottom-alert></salla-bottom-alert>
    </div>
  </div>
</footer>
