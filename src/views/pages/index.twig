{# Salla Theme — Homepage with customisable components #}
{% extends 'layouts/master.twig' %}

{% block content %}
    {% component 'home.enhanced-slider' %}
    {% component 'home.main-links' %}
    {% component 'home.slider-products-with-header' %}
    {% component 'home.enhanced-square-banners' %}
    {% component 'home.brands' %}
    {% component 'home.custom-testimonials' %}
    {% component 'home.converted-featured-products' %}
    {% component 'home.converted-hero' %}
    {% component 'home.converted-featured-products-2' %}
    {% component 'home.converted-featured-products-3' %}
    {% component 'home.converted-newsletter' %}
    {% component 'home.converted-footer' %}
{% endblock %}

{% block scripts %}
    <script defer src="{{ 'home.js' | asset }}"></script>
{% endblock %}
