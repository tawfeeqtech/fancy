{# Product Detail Page #}
{% extends "layouts.master" %}

{% block content %}
<div class="product-page" dir="auto">
    <div class="container">
        {# Breadcrumbs #}
        {% if theme.settings.get('product_show_breadcrumbs') %}
            {% component 'breadcrumb' %}
        {% endif %}
        
        <div class="product-layout">
            {# Product Gallery #}
            <div class="product-gallery">
                <salla-product-gallery></salla-product-gallery>
            </div>
            
            {# Product Info #}
            <div class="product-info">
                <h1 class="product-title">{{ product.name }}</h1>
                
                {# Price + Installment #}
                <div class="product-price">
                    <salla-product-price></salla-product-price>
                    <salla-installment></salla-installment>
                </div>
                
                {# Description #}
                <div class="product-description">
                    {{ product.description | raw }}
                </div>
                
                {# Options + Variants #}
                <salla-product-options></salla-product-options>
                
                {# Availability (notify when available + WhatsApp) #}
                <salla-product-availability></salla-product-availability>
                
                {# Add to Cart #}
                <salla-add-to-cart>
                    <salla-add-product-button></salla-add-product-button>
                </salla-add-to-cart>
                
                {# Gifting (if enabled) #}
                <salla-gifting></salla-gifting>
                
                {# Loyalty Points #}
                <salla-loyalty></salla-loyalty>
                
                {# Share #}
                <salla-social-share></salla-social-share>
                
                {# Comments #}
                <salla-comments></salla-comments>
            </div>
        </div>
        
        {# Related Products #}
        <salla-related-products></salla-related-products>
    </div>
</div>
{% endblock %}

{% block scripts %}
    <script defer src="{{ 'product.js' | asset }}"></script>
{% endblock %}
